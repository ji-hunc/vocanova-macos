<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Sign in with Apple은 Developer ID 배포에서 Apple이 지원하지 않음
	  (Developer ID PP에 com.apple.developer.applesignin entitlement을 발급해주지 않음).
	  외부 배포로 전환하면서 이 entitlement는 일단 제거. SiwA를 살리려면 추후
	  Services ID + ASWebAuthenticationSession 기반 웹 OAuth로 교체 필요.
	-->
</dict>
</plist>
